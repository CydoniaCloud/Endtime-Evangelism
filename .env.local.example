# Site -----------------------------------------------------------------------
# Used in metadata, OG images, sitemap.xml, RSS feed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="The Living Word"

# Newsletter -----------------------------------------------------------------
# Pick ONE provider. If both are set, Buttondown wins (it has native double
# opt-in; Resend's audiences API is single opt-in only).
#
# Buttondown — sign up at https://buttondown.email, then Account → API
# BUTTONDOWN_API_KEY=
#
# Resend — https://resend.com, create an Audience, then Settings → API Keys
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=

# Analytics ------------------------------------------------------------------
# Pick ONE. Leave both empty to disable analytics entirely.
#
# Plausible — https://plausible.io, use your tracked domain
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=livingword.example
#
# Umami — your self-hosted or cloud Umami instance
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
